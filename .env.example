# Copy to `.env` (git-ignored) and fill in. NEVER commit real values.
# Self-custody signing stays local — see the vault note "Security and Encryption".

# --- CoinMarketCap AI Agent Hub (data + x402) ---
CMC_API_KEY=

# --- BscScan (on-chain analytics) ---
BSCSCAN_API_KEY=

# --- Trust Wallet Agent Kit (TWAK) — execution + self-custody signing ---
# These are the names the twak CLI (v0.19.0) actually reads. Normally you don't need them
# here at all: `twak setup` writes ~/.twak/credentials.json. Env form is for CI/containers.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Wallet password: prefer the OS keychain (`twak wallet keychain save`; works on Windows
# Credential Manager too — verified). TWAK_WALLET_PASSWORD is the container/CI fallback only.
# TWAK_WALLET_PASSWORD=

# --- Agent wallet (local custody) ---
# The PUBLIC address only (not a secret). Keys stay in ~/.twak/wallet.json (encrypted).
# AGENT_WALLET_ADDRESS=

# --- BNB Chain ---
BSC_RPC_URL=https://bsc-dataseed.binance.org

# --- Apentic results publishing (training host only; NOT a signing key) ---
# Where the self-publishing job uploads run bundles + invalidates CloudFront. Lives on the
# DESKTOP training host's .env. Creds = a scoped IAM user: PutObject/GetObject on the bucket/*,
# ListBucket on the bucket (so a missing manifest 404s instead of 403), and
# cloudfront:CreateInvalidation. Never the GitHub OIDC deploy role.
# Served at root by a dedicated distribution on data.alexlouis.dev (frontend:
# PUBLIC_APENTIC_DATA=https://data.alexlouis.dev). Dist id = the DATA distribution, not the site's.
# APENTIC_PUBLISH_TARGET=s3://alexlouis-apentic-data
# APENTIC_CLOUDFRONT_DIST_ID=<data.alexlouis.dev distribution id>
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# REMOTE_TRAIN_S3_ENDPOINT=        # leave empty for AWS S3; set only for S3-compatible (e.g. R2)
