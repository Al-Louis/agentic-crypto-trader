# Secrets & keys — NEVER commit (self-custody stays local)
.env
.env.*
!/.env.example
*.key
*.pem
*.keystore
wallet.json
mnemonic*
keystore/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/

# venv (created via `python -m venv .venv`) is ignored above

# Data / runs / models (may be large)
data/raw/
data/*.parquet
data/ohlcv/
data/anchor/
data/features/
data/*.json
data/*.csv
# Risk ledger: tx hashes + trade sizes (no secrets, but operational state — never committed)
data/*.jsonl

# TradeSim reference seed (large: models/data/frontend; lessons captured in the vault)
/tradesim_handoff_seed/
/tradesim_handoff_seed.zip
runs/
experiments/*
# …but the experiment ledger MUST be version-controlled (the permanent performance trail)
!experiments/ledger.jsonl
!experiments/champion.json
models/
*.log
logs/

# Generated infra-provisioning output (resource ids, not secrets)
.deploy/*.out.json
apentic-iam.json

# Vendored SDK clones — keep provenance (_SOURCE.md), drop the third-party source.
# (trust-wallet-agent-kit is doc-only markdown, so it stays tracked.)
.obsidian-vault/References/bnb-ai-agent-sdk/*
!.obsidian-vault/References/bnb-ai-agent-sdk/_SOURCE.md
.obsidian-vault/References/coinmarketcap-cli/*
!.obsidian-vault/References/coinmarketcap-cli/_SOURCE.md

# OS / editor
.DS_Store
.idea/
.vscode/
