{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GetPrivateModels",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::alexlouis-act-private/models/*"
    },
    {
      "Sid": "ListPrivateModelsPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::alexlouis-act-private",
      "Condition": { "StringLike": { "s3:prefix": "models/*" } }
    }
  ]
}
