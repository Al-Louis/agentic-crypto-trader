# /etc/trader/trader.env — the trading host's environment file.
# Install EMPTY first, then fill with sudoedit (secrets never touch shell history):
#   sudo install -d -m 0755 /etc/trader
#   sudo install -m 0600 -o root -g root deploy/trader.env.template /etc/trader/trader.env
#   sudoedit /etc/trader/trader.env
# MUST stay root:root 0600. NEVER commit a filled copy. NEVER `cat` it in a session an
# agent can read — verify with permissions/key-name checks only (deploy/verify-host.sh).

# --- TWAK wallet unlock (the live-week signing credential) ---
# The headless-Linux unlock path: no Secret Service on a server, so systemd injects this
# into the loop process. See the runbook's key-ceremony section for why this is the
# accepted posture for a bankroll-sized competition wallet.
TWAK_WALLET_PASSWORD=

# --- TWAK API credentials ---
# Normally NOT needed here: `twak setup` (run as the trader user) writes
# ~trader/.twak/credentials.json (0600). Uncomment only if credentials.json is absent.
# TWAK_ACCESS_ID=
# TWAK_HMAC_SECRET=

# --- Data surfaces ---
CMC_API_KEY=
BSCSCAN_API_KEY=
BSC_RPC_URL=https://bsc-dataseed.binance.org

# --- Agent wallet (public address only — not a secret) ---
AGENT_WALLET_ADDRESS=

# --- Loop mode (paper for the June 16-21 forward-run, live for June 22-28) ---
# Read by `python -m trader.agent` when no --mode flag is given (invalid value = loud
# refusal, not silent paper). Going live takes BOTH lines below — TRADER_MODE=live AND
# AGENT_ALLOW_LIVE=1 — so a single stray edit can never open the signing path (Phase H).
TRADER_MODE=paper
# AGENT_ALLOW_LIVE=1

# --- Telemetry publishing (trading/ prefix on the data bucket) ---
# NO AWS keys here: S3 access comes from the EC2 instance role (put-only on trading/*).
APENTIC_PUBLISH_TARGET=s3://alexlouis-apentic-data/trading
AWS_DEFAULT_REGION=us-east-1
